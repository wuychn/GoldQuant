# 复制为 `.env` 后按需修改（环境变量前缀均为 GOLDQUANT_）

# 运行环境标识（仅用于 / 根路径展示等）
GOLDQUANT_ENV=local

# API 版本前缀
GOLDQUANT_API_V1_STR=/api/v1

# 开发启动（python -m app / run.ps1 / run.sh）时的监听地址与端口（已固定读取「项目根目录」下的 .env）
GOLDQUANT_HOST=0.0.0.0
GOLDQUANT_PORT=8000
# 若使用裸命令 `uvicorn app.main:app` 且未写 --port，监听端口由 Uvicorn 默认 8000 决定，不会读此项；请改用 python -m app，或：uvicorn app.main:app --port 8085
# 是否启用热重载（生产环境可设为 false，并用 uvicorn 命令行不带 reload）
GOLDQUANT_UVICORN_RELOAD=true

# CORS：单个 `*` 或逗号分隔多个源，如 http://localhost:3000,https://app.example.com
GOLDQUANT_CORS_ORIGINS=*
# 是否允许携带 Cookie（当 CORS_ORIGINS 为 `*` 时内部会强制为 false）
GOLDQUANT_CORS_ALLOW_CREDENTIALS=false

# 同花顺等 HTTP 请求超时（秒）
GOLDQUANT_HTTP_CLIENT_TIMEOUT=30

# 同花顺热榜接口基址（一般无需修改）
GOLDQUANT_THS_HOT_URL=https://dq.10jqka.com.cn/fuyao/hot_list_data/out/hot_list/v1/stock

# 访问同花顺时使用的 User-Agent（部分环境需模拟浏览器）
GOLDQUANT_THS_DEFAULT_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# 出站代理（AKShare / 同花顺 httpx 等全部走此配置；关闭时勿写 true 或保持 false）
GOLDQUANT_PROXY_ENABLED=false
# 示例：本地 Clash / V2：http://127.0.0.1:7890
GOLDQUANT_PROXY_URL=
# 若 HTTP 与 HTTPS 需不同代理，可分别覆盖（留空则回退到 PROXY_URL）
# GOLDQUANT_PROXY_HTTP_URL=
# GOLDQUANT_PROXY_HTTPS_URL=
GOLDQUANT_PROXY_NO_PROXY=localhost,127.0.0.1
